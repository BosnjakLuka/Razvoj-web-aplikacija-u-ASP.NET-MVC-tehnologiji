{
  "hooks": {
    "UserPromptSubmit": [
      {
        "type": "command",
        "command": "pwsh -NoProfile -File ./.github/hooks/log-agent-input.ps1",
        "windows": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File .\\.github\\hooks\\log-agent-input.ps1",
        "timeout": 15
      }
    ],
    "PreToolUse": [
      {
        "type": "command",
        "command": "pwsh -NoProfile -File ./.github/hooks/log-agent-input.ps1",
        "windows": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File .\\.github\\hooks\\log-agent-input.ps1",
        "timeout": 15
      }
    ]
  }
}
